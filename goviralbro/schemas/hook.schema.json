{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "hook.schema.json",
  "title": "Content Hook",
  "description": "A hook generated by HookGenie from a content angle using one of 6 proven patterns.",
  "type": "object",
  "required": ["id", "angle_id", "platform", "pattern", "hook_text", "score", "created_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique hook ID (e.g., hook_20260304_001)"
    },
    "angle_id": {
      "type": "string",
      "description": "Reference to the source angle ID"
    },
    "platform": {
      "type": "string",
      "enum": ["youtube_longform", "youtube_shorts", "instagram_reels", "tiktok", "linkedin"],
      "description": "Target platform this hook is optimized for"
    },
    "pattern": {
      "type": "string",
      "enum": ["contradiction", "specificity", "timeframe_tension", "pov_as_advice", "vulnerable_confession", "pattern_interrupt"],
      "description": "Which of the 6 HookGenie patterns was used"
    },
    "hook_text": {
      "type": "string",
      "description": "The actual hook line"
    },
    "visual_cue": {
      "type": "string",
      "description": "What to show on screen in first 3 seconds (short-form platforms)"
    },
    "score": {
      "type": "object",
      "required": ["contrast_fit", "pattern_strength", "platform_fit", "composite"],
      "properties": {
        "contrast_fit": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "How well this hook leverages the A-to-B contrast (0-10)"
        },
        "pattern_strength": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "How well the pattern matches this content type (0-10)"
        },
        "platform_fit": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "How native this hook feels for the platform (0-10)"
        },
        "composite": {
          "type": "number",
          "minimum": 0,
          "maximum": 10,
          "description": "Weighted score: contrast_fit * 0.4 + pattern_strength * 0.35 + platform_fit * 0.25"
        }
      }
    },
    "cta_pairing": {
      "type": "string",
      "description": "Suggested CTA that pairs with this hook's promise"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "used", "winner", "dud"],
      "default": "draft",
      "description": "Lifecycle status — winner/dud set by /analyze"
    },
    "performance": {
      "type": "object",
      "description": "Performance data populated by /viral:analyze",
      "properties": {
        "ctr": { "type": "number", "description": "Click-through rate" },
        "retention_30s": { "type": "number", "description": "30-second retention percentage" },
        "engagement_rate": { "type": "number", "description": "Engagement rate" },
        "analyzed_at": { "type": "string", "format": "date-time" }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": ["original", "swipe"],
      "default": "original",
      "description": "Whether this hook was generated fresh by HookGenie ('original') or inspired by a competitor swipe hook ('swipe')"
    },
    "swipe_reference": {
      "type": "string",
      "description": "If source is 'swipe', the swipe hook ID that inspired this (e.g., swipe_20260305_001)"
    }
  },
  "additionalProperties": false
}
